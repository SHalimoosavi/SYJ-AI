# Copy this file to .env and adjust as needed. Never commit your real .env.

# Where SYJ AI writes generated project files.
SYJ_WORKSPACE=./syj_workspace

# Local Ollama server (default is correct for most setups, incl. Termux).
OLLAMA_HOST=http://localhost:11434
SYJ_OLLAMA_TIMEOUT=180

# Models used for each role. Pull them first with:
#   ollama pull qwen2.5-coder:7b
#   ollama pull deepseek-r1:7b
SYJ_CODING_MODEL=qwen2.5-coder:7b
SYJ_REASONING_MODEL=deepseek-r1:7b

# Remote fallback (disabled by default — SYJ AI is local-first).
# Only takes effect if Ollama cannot be reached.
SYJ_ENABLE_REMOTE_FALLBACK=false
SYJ_FALLBACK_MODEL=claude-sonnet-4-6
# ANTHROPIC_API_KEY=sk-ant-...

# Require interactive confirmation before running shell commands.
SYJ_REQUIRE_SHELL_CONFIRMATION=true

# Logging verbosity: DEBUG | INFO | WARNING | ERROR
SYJ_LOG_LEVEL=INFO
